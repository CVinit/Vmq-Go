APP_PORT=8080
VMQ_IMAGE=ghcr.io/cvinit/vmq-go:latest
SESSION_SECRET=replace-with-a-random-string-at-least-32-chars
ADMIN_USER=replace-admin-user
ADMIN_PASS=replace-admin-password
COOKIE_SECURE=0
POSTGRES_DB=vmq
POSTGRES_USER=vmq
POSTGRES_PASSWORD=replace-postgres-password
DATABASE_URL=postgres://vmq:vmq@postgres:5432/vmq?sslmode=disable
ADMIN_SESSION_TTL_HOURS=720
ALLOW_INSECURE_DEV_DEFAULTS=0
ALLOW_PRIVATE_CALLBACKS=0
TRUSTED_PROXY_CIDRS=
TRUST_CLOUDFLARE_IPS=0
